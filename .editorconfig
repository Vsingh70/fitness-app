root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{ts,tsx,js,jsx,mjs,cjs,json,jsonc,yml,yaml,css,scss,html}]
indent_style = space
indent_size = 2

[*.py]
indent_style = space
indent_size = 4

[*.swift]
indent_style = tab
indent_size = 4

[Makefile]
indent_style = tab

[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false
