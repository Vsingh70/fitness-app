{
  "name": "gym-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "openapi:generate": "openapi-typescript ../../packages/openapi/openapi.json -o src/lib/api/types.ts && prettier --write src/lib/api/types.ts",
    "openapi:generate:live": "openapi-typescript http://localhost:8000/openapi.json -o src/lib/api/types.ts && prettier --write src/lib/api/types.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "perf": "vitest run tests/perf",
    "perf:bundle": "node scripts/check-bundle-budgets.mjs",
    "perf:e2e": "playwright test e2e/perf"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@tanstack/react-query": "^5.62.7",
    "@tanstack/react-virtual": "^3.14.3",
    "@zxing/browser": "^0.2.0",
    "clsx": "^2.1.1",
    "localforage": "^1.10.0",
    "lucide-react": "^0.469.0",
    "motion": "^12.40.0",
    "next": "15.5.19",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^2.6.0",
    "uuid": "^14.0.0",
    "vaul": "^1.1.2",
    "zod": "^3.24.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@types/uuid": "^11.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^9.18.0",
    "eslint-config-next": "15.5.19",
    "jsdom": "^29.1.1",
    "openapi-typescript": "^7.5.2",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.7"
  },
  "packageManager": "pnpm@11.3.0"
}
