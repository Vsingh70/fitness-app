{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "panels": [
    {
      "type": "timeseries",
      "title": "Ollama latency p50/p95",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, endpoint, model) (rate(ollama_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 {{endpoint}} {{model}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, endpoint, model) (rate(ollama_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{endpoint}} {{model}}",
          "refId": "B"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "type": "timeseries",
      "title": "Ollama outcomes / sec",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (outcome) (rate(ollama_requests_total[1m]))",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "type": "stat",
      "title": "Ollama process resident memory",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=\"ollama\"}",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    }
  ],
  "schemaVersion": 39,
  "tags": ["gymapp", "ollama"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "title": "Ollama",
  "uid": "gymapp-ollama",
  "version": 1
}
