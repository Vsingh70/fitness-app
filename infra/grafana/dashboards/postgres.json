{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "panels": [
    {
      "type": "timeseries",
      "title": "Connections",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(pg_stat_database_numbackends{datname=\"gym\"})",
          "legendFormat": "active",
          "refId": "A"
        },
        {
          "expr": "pg_settings_max_connections",
          "legendFormat": "max",
          "refId": "B"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "Transactions / sec",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(pg_stat_database_xact_commit{datname=\"gym\"}[1m])",
          "legendFormat": "commits",
          "refId": "A"
        },
        {
          "expr": "rate(pg_stat_database_xact_rollback{datname=\"gym\"}[1m])",
          "legendFormat": "rollbacks",
          "refId": "B"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "type": "stat",
      "title": "Disk usage (gym DB)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "pg_database_size_bytes{datname=\"gym\"}",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "type": "stat",
      "title": "Volume free %",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "(node_filesystem_avail_bytes{mountpoint=\"/var/lib/gymapp/postgres\"} / node_filesystem_size_bytes{mountpoint=\"/var/lib/gymapp/postgres\"})",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "percentunit" } }
    }
  ],
  "schemaVersion": 39,
  "tags": ["gymapp", "postgres"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "title": "Postgres",
  "uid": "gymapp-postgres",
  "version": 1
}
