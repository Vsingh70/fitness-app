{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "panels": [
    {
      "type": "timeseries",
      "title": "Sync outcomes / hour",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (outcome) (rate(fitbit_sync_total[1h]) * 3600)",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "type": "stat",
      "title": "Error ratio (last 1h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(fitbit_sync_total{outcome!=\"success\"}[1h])) / sum(rate(fitbit_sync_total[1h]))",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percentunit" } }
    },
    {
      "type": "stat",
      "title": "Rate-limit hits (last 1h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(fitbit_sync_total{outcome=\"rate_limited\"}[1h]))",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 }
    }
  ],
  "schemaVersion": 39,
  "tags": ["gymapp", "fitbit"],
  "templating": { "list": [] },
  "time": { "from": "now-24h", "to": "now" },
  "title": "Fitbit sync",
  "uid": "gymapp-fitbit-sync",
  "version": 1
}
