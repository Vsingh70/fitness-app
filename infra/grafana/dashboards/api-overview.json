{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "panels": [
    {
      "type": "timeseries",
      "title": "Request rate (RPS)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (status_class) (rate(http_requests_total[1m]))",
          "legendFormat": "{{status_class}}",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "type": "timeseries",
      "title": "Latency p50 / p95 / p99",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, route) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 {{route}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, route) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{route}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, route) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p99 {{route}}",
          "refId": "C"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "type": "stat",
      "title": "Error rate (5xx + 4xx)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status_class=~\"4xx|5xx\"}[5m])) / sum(rate(http_requests_total[5m]))",
          "legendFormat": "error rate",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "percentunit" } }
    },
    {
      "type": "stat",
      "title": "Slowest route (p95 last 5m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "topk(1, histogram_quantile(0.95, sum by (le, route) (rate(http_request_duration_seconds_bucket[5m]))))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" } }
    }
  ],
  "schemaVersion": 39,
  "tags": ["gymapp", "api"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "API overview",
  "uid": "gymapp-api-overview",
  "version": 1
}
