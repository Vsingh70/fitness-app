services:
  postgres-exporter:
    image: {{ monitoring_postgres_exporter_image }}
    container_name: gymapp-postgres-exporter
    restart: unless-stopped
    env_file:
      - /etc/gymapp/exporters.env
    ports:
      - "127.0.0.1:{{ monitoring_postgres_exporter_port }}:9187"
    extra_hosts:
      - "host.docker.internal:host-gateway"

  redis-exporter:
    image: {{ monitoring_redis_exporter_image }}
    container_name: gymapp-redis-exporter
    restart: unless-stopped
    env_file:
      - /etc/gymapp/exporters.env
    ports:
      - "127.0.0.1:{{ monitoring_redis_exporter_port }}:9121"
    extra_hosts:
      - "host.docker.internal:host-gateway"
