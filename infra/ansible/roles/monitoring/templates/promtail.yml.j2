server:
  http_listen_port: 9080
  grpc_listen_port: 0
  log_level: info

positions:
  filename: /var/lib/promtail/positions.yaml

clients:
  - url: {{ monitoring_loki_endpoint }}
    basic_auth:
      username: {{ vault_loki_username }}
      password: {{ vault_loki_password }}
    backoff_config:
      min_period: 500ms
      max_period: 5m
      max_retries: 10

scrape_configs:
  - job_name: gymapp
    static_configs:
      - targets:
          - localhost
        labels:
          job: gymapp
          host: "{{ inventory_hostname }}"
          __path__: /var/log/gymapp-*.log

  - job_name: caddy
    static_configs:
      - targets:
          - localhost
        labels:
          job: caddy
          host: "{{ inventory_hostname }}"
          __path__: /var/log/caddy/*.log

  - job_name: docker
    docker_sd_configs:
      - host: unix:///var/run/docker.sock
        refresh_interval: 15s
    relabel_configs:
      - source_labels: [__meta_docker_container_name]
        target_label: container
      - source_labels: [__meta_docker_container_log_stream]
        target_label: stream
