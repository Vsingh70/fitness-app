ENVIRONMENT=prod
LOG_FORMAT=json
LOG_LEVEL=INFO

# Postgres + Redis run as containers on the shared `gymapp_default` network, so
# the app reaches them by CONTAINER NAME (not host.docker.internal — they bind to
# 127.0.0.1 on the host, which containers can't reach via the bridge gateway).
# Note: in-container postgres always listens on 5432, redis on 6379, regardless
# of the host-side published port.
DATABASE_URL=postgresql+asyncpg://{{ postgres_user }}:{{ vault_postgres_password }}@gymapp-postgres:5432/{{ postgres_db }}
REDIS_URL=redis://gymapp-redis:6379/0
# Ollama runs as a HOST process (not a container) bound to all interfaces, so it
# is reachable from containers via the docker bridge gateway.
OLLAMA_URL=http://host.docker.internal:11434

JWT_SECRET={{ vault_app_jwt_secret }}
JWT_ACCESS_TTL_MINUTES=15
REFRESH_TTL_DAYS=60

APPLE_BUNDLE_IDS={{ vault_app_apple_bundle_ids }}
GOOGLE_CLIENT_IDS={{ vault_app_google_client_ids }}

# Google Health API (replaces legacy Fitbit). Read-only health ingest.
GOOGLE_HEALTH_CLIENT_ID={{ vault_google_health_client_id | default("") }}
GOOGLE_HEALTH_CLIENT_SECRET={{ vault_google_health_client_secret | default("") }}
GOOGLE_HEALTH_REDIRECT_URI=https://{{ app_domain }}/integrations/health/callback

FITBIT_CLIENT_ID={{ vault_app_fitbit_client_id }}
FITBIT_CLIENT_SECRET={{ vault_app_fitbit_client_secret }}
FITBIT_TOKEN_KEY={{ vault_app_fitbit_token_key }}
FITBIT_WEBHOOK_SIGNING_SECRET={{ vault_app_fitbit_webhook_signing_secret }}
FITBIT_WEBHOOK_SUBSCRIBER_VERIFICATION={{ vault_app_fitbit_webhook_subscriber_verification }}
FITBIT_REDIRECT_URI=https://{{ app_domain }}/integrations/fitbit/callback
