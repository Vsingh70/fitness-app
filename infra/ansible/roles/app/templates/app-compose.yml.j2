services:
  # One-shot migration job. The api + worker depend on this completing
  # successfully so a deploy never serves traffic against a stale schema.
  migrate:
    image: {{ app_image }}
    container_name: gymapp-migrate
    restart: "no"
    command: ["alembic", "upgrade", "head"]
    env_file:
      - /etc/gymapp/app.env
    networks:
      - gymapp
    extra_hosts:
      - "host.docker.internal:host-gateway"

  api:
    image: {{ app_image }}
    container_name: gymapp-api
    restart: unless-stopped
    depends_on:
      migrate:
        condition: service_completed_successfully
    env_file:
      - /etc/gymapp/app.env
    volumes:
      - {{ app_meal_photos_dir }}:/var/lib/gymapp/meal-photos
    ports:
      - "127.0.0.1:{{ app_port }}:8000"
    networks:
      - gymapp
    extra_hosts:
      - "host.docker.internal:host-gateway"
    healthcheck:
      test: ["CMD", "python", "-c", "import urllib.request; urllib.request.urlopen('http://127.0.0.1:8000/v1/health').read()"]
      interval: 30s
      timeout: 5s
      retries: 5
      start_period: 30s

  worker:
    image: {{ app_image }}
    container_name: gymapp-worker
    restart: unless-stopped
    depends_on:
      migrate:
        condition: service_completed_successfully
    command: ["uv", "run", "arq", "app.workers.main.WorkerSettings"]
    env_file:
      - /etc/gymapp/app.env
    volumes:
      - {{ app_meal_photos_dir }}:/var/lib/gymapp/meal-photos
    networks:
      - gymapp
    extra_hosts:
      - "host.docker.internal:host-gateway"

# Join the existing network created by the postgres/redis compose project so the
# app can reach gymapp-postgres / gymapp-redis by container name.
networks:
  gymapp:
    external: true
    name: gymapp_default
