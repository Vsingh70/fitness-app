{
{% if not app_use_internal_tls | default(false) %}
  email {{ app_letsencrypt_email }}
{% endif %}
  # Global metrics option (the nested `servers { metrics }` form is deprecated).
  metrics
}

{% if app_use_internal_tls | default(false) %}
# No public domain yet: bind to the host IP and use Caddy's internal self-signed
# CA so the API is reachable over HTTPS for testing. Browsers/clients will warn
# about the untrusted cert until a real domain + Let's Encrypt is wired in.
https://{{ app_address | default(ansible_host) }} {
  tls internal
{% else %}
{{ app_domain }} {
{% endif %}
  encode zstd gzip

  # API proxy
  reverse_proxy 127.0.0.1:{{ app_port }} {
    transport http {
      response_header_timeout 90s
    }
    header_up X-Real-IP {remote}
  }

  # Signed meal-photo URLs are served directly from disk. The API issues
  # the signed URL; Caddy enforces the path mapping. Directory browsing is off
  # by default in current Caddy (the old `browse=off` argument was removed).
  handle_path /meal-photos/* {
    root * {{ app_meal_photos_dir }}
    file_server
  }

  header {
{% if not app_use_internal_tls | default(false) %}
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
{% endif %}
    X-Content-Type-Options nosniff
    Referrer-Policy strict-origin-when-cross-origin
    -Server
  }

  log {
    output file /var/log/caddy/access.log {
      roll_size 10mb
      roll_keep 5
    }
    format json
  }
}
