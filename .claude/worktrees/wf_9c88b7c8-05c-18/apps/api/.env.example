# API environment. Copy to .env and fill in.
# Settings are read by app/config.py (pydantic-settings).

# Runtime mode: dev | test | prod
ENVIRONMENT=dev

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Database (SQLAlchemy async URL, asyncpg driver)
DATABASE_URL=postgresql+asyncpg://gym:gym@localhost:5433/gym

# Redis (used by ARQ)
REDIS_URL=redis://localhost:6379/0

# Ollama (used by AI tasks; unused until later phases)
OLLAMA_URL=http://localhost:11434

# Build identifier, baked in by the Dockerfile via --build-arg GIT_SHA.
# Leave 'dev' for local.
GIT_SHA=dev

# Auth
# HS256 secret for access tokens. Generate with: openssl rand -hex 32
JWT_SECRET=
JWT_ACCESS_TTL_MINUTES=15
REFRESH_TTL_DAYS=60

# Comma-separated allowed Apple aud values (iOS bundle id + web service id).
# Empty in dev means /v1/auth/apple returns 503.
APPLE_BUNDLE_IDS=

# Comma-separated allowed Google client ids (iOS, web). Empty means /v1/auth/google returns 503.
GOOGLE_CLIENT_IDS=
