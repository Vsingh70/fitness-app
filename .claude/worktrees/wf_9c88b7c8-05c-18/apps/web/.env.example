# Web environment. Copy to .env.local and fill in.

# Public: visible in the browser. Only use this for the API base if the browser
# needs to call it directly. We proxy via /api/proxy/* so this is mostly informational.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Server-only: the backend URL the Next.js server uses when proxying.
# In Docker compose prod this is the internal service hostname.
BACKEND_INTERNAL_URL=http://localhost:8000

# Sign-in client IDs. Leave empty to render a 'not configured' message on /sign-in.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_APPLE_SERVICE_ID=
# Apple JS redirect URI (must match what's registered in the Apple Service ID).
NEXT_PUBLIC_APPLE_REDIRECT_URI=http://localhost:3000/sign-in/callback

# Cookie security. In dev (http) cookies cannot be Secure; flip these on for prod.
COOKIE_SECURE=false
COOKIE_DOMAIN=
